<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Pytania SG — trener egzaminacyjny</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --pine:#0C2119;
    --pine-2:#123326;
    --field:#F5F7F2;
    --card:#FFFFFF;
    --line:#D8DFD4;
    --ink:#16211C;
    --muted:#5F6F66;
    --go:#1F6F4A;
    --stop:#A62B21;
    --mark:#E8B23A;
    --radius:14px;
    --font-d:'Bricolage Grotesque',system-ui,sans-serif;
    --font-b:'Inter',system-ui,-apple-system,sans-serif;
    --font-m:'JetBrains Mono',ui-monospace,monospace;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{
    background:var(--field);
    color:var(--ink);
    font-family:var(--font-b);
    font-size:16px;
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  /* --- pas graniczny: sygnaturowy element --- */
  .post{
    height:8px;
    background:repeating-linear-gradient(135deg,var(--stop) 0 14px,#fff 14px 28px);
  }
  header{
    background:var(--pine);
    color:#EAF1EC;
    padding:22px 20px 18px;
  }
  .wrap{max-width:860px;margin:0 auto}
  .brand{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap}
  h1{
    font-family:var(--font-d);
    font-weight:800;
    font-size:clamp(22px,4vw,30px);
    letter-spacing:-.02em;
    margin:0;
  }
  .sub{color:#9CB6A7;font-size:13px;font-family:var(--font-m)}
  nav{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap}
  nav button{
    font-family:var(--font-b);font-size:14px;font-weight:600;
    background:transparent;color:#B9CFC1;
    border:1px solid #2C4A3B;border-radius:999px;
    padding:8px 16px;cursor:pointer;transition:.15s;
  }
  nav button:hover{border-color:#4E7B65;color:#EAF1EC}
  nav button[aria-current="true"]{background:#EAF1EC;color:var(--pine);border-color:#EAF1EC}
  main{padding:24px 20px 80px}
  .card{
    background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
    padding:22px;
  }
  .qnum{
    font-family:var(--font-m);font-size:12px;font-weight:700;
    color:var(--muted);letter-spacing:.08em;text-transform:uppercase;
    display:flex;justify-content:space-between;align-items:center;gap:10px;
  }
  .qtext{
    font-family:var(--font-d);font-weight:600;font-size:clamp(18px,2.6vw,22px);
    line-height:1.35;letter-spacing:-.01em;margin:10px 0 18px;
  }
  ul.opts{list-style:none;margin:0;padding:0;display:grid;gap:9px}
  .opt{
    display:flex;gap:12px;align-items:flex-start;width:100%;text-align:left;
    background:#FBFCFA;border:1px solid var(--line);border-radius:10px;
    padding:12px 14px;font:inherit;color:inherit;cursor:pointer;transition:.12s;
  }
  .opt:hover:not(:disabled){border-color:#9DB3A6;background:#fff}
  .opt:disabled{cursor:default}
  .opt .k{
    font-family:var(--font-m);font-weight:700;font-size:13px;color:var(--muted);
    border:1px solid var(--line);border-radius:6px;min-width:24px;height:24px;
    display:grid;place-items:center;flex:none;background:#fff;
  }
  .opt.good{border-color:var(--go);background:#EEF7F1}
  .opt.good .k{background:var(--go);color:#fff;border-color:var(--go)}
  .opt.bad{border-color:var(--stop);background:#FBEFEE}
  .opt.bad .k{background:var(--stop);color:#fff;border-color:var(--stop)}
  .bar{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:20px}
  .btn{
    font-family:var(--font-b);font-weight:600;font-size:14px;
    border-radius:999px;padding:10px 18px;cursor:pointer;border:1px solid var(--pine);
    background:var(--pine);color:#fff;transition:.15s;
  }
  .btn:hover{background:var(--pine-2)}
  .btn.ghost{background:#fff;color:var(--pine)}
  .btn.ghost:hover{background:#EEF2EC}
  .btn:disabled{opacity:.4;cursor:not-allowed}
  .btn.mark[aria-pressed="true"]{background:var(--mark);border-color:var(--mark);color:#3A2A05}
  .spacer{flex:1}
  .meter{height:6px;background:#E3E9E0;border-radius:99px;overflow:hidden;margin:14px 0 0}
  .meter i{display:block;height:100%;background:var(--go);transition:width .3s}
  .muted{color:var(--muted);font-size:13px}
  .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:16px}
  input[type=search],select{
    font:inherit;font-size:14px;padding:9px 12px;border:1px solid var(--line);
    border-radius:10px;background:#fff;color:inherit;
  }
  input[type=search]{flex:1;min-width:180px}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(44px,1fr));gap:6px;margin-top:14px}
  .grid button{
    font-family:var(--font-m);font-size:12px;font-weight:700;padding:8px 0;
    border:1px solid var(--line);background:#fff;border-radius:8px;cursor:pointer;color:var(--muted);
  }
  .grid button:hover{border-color:var(--pine)}
  .grid button.cur{background:var(--pine);color:#fff;border-color:var(--pine)}
  .grid button.ok{border-color:var(--go);color:var(--go)}
  .grid button.err{border-color:var(--stop);color:var(--stop)}
  .grid button.mk{background:#FDF4DF;border-color:var(--mark)}
  .score{font-family:var(--font-d);font-weight:800;font-size:52px;letter-spacing:-.03em;line-height:1}
  .kbd{font-family:var(--font-m);font-size:11px;border:1px solid var(--line);border-bottom-width:2px;border-radius:5px;padding:1px 5px;background:#fff}
  .list-item{border-top:1px solid var(--line);padding:14px 0}
  .list-item:first-child{border-top:0}
  .tag{font-family:var(--font-m);font-size:11px;font-weight:700;padding:2px 7px;border-radius:5px;background:#EEF2EC;color:var(--muted)}
  .tag.err{background:#FBEFEE;color:var(--stop)}
  .tag.ok{background:#EEF7F1;color:var(--go)}
  .stat{display:flex;gap:20px;flex-wrap:wrap;margin-top:8px}
  .stat div b{font-family:var(--font-m);font-size:20px;display:block}
  footer{padding:24px 20px 40px;text-align:center}
  @media (max-width:520px){ .card{padding:16px} .bar .btn{flex:1} }
  @media (prefers-reduced-motion:reduce){*{transition:none!important}}
  :focus-visible{outline:2px solid var(--mark);outline-offset:2px}
</style>
</head>
<body>
<div class="post"></div>
<header>
  <div class="wrap">
    <div class="brand">
      <h1>Pytania SG</h1>
      <span class="sub" id="count">200 pytań</span>
    </div>
    <nav id="nav">
      <button data-view="learn" aria-current="true">Nauka</button>
      <button data-view="test">Test 20 pytań</button>
      <button data-view="review">Do powtórki</button>
      <button data-view="browse">Lista pytań</button>
