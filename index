const KEYS = ['a','b','c','d'];
const TEST_SIZE = 20;

/* --- pamięć postępu (działa też bez localStorage) --- */
const store = (() => {
  let mem = {};
  const ok = (() => { try { localStorage.setItem('_t','1'); localStorage.removeItem('_t'); return true; } catch(e){ return false; } })();
  return {
    get(k, d){ try { return ok ? JSON.parse(localStorage.getItem('sg_'+k)) ?? d : (mem[k] ?? d); } catch(e){ return d; } },
    set(k, v){ try { ok ? localStorage.setItem('sg_'+k, JSON.stringify(v)) : (mem[k]=v); } catch(e){ mem[k]=v; } }
  };
})();

const state = {
  view: 'learn',
  learnIdx: 0,
  learnReveal: false,
  learnPick: null,
  marked: new Set(store.get('marked', [])),
  wrong: new Set(store.get('wrong', [])),
  right: new Set(store.get('right', [])),
  test: null,
  reviewIdx: 0,
  reviewReveal: false,
  reviewPick: null,
  query: ''
};
const save = () => {
  store.set('marked', [...state.marked]);
  store.set('wrong', [...state.wrong]);
  store.set('right', [...state.right]);
};
const byId = id => QUESTIONS.find(q => q.id === id);
const esc = s => s.replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c]));
const shuffle = a => { a = a.slice(); for (let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; } return a; };
const app = document.getElementById('app');
document.getElementById('count').textContent = QUESTIONS.length + ' pytań';

/* --- widok: karta pytania --- */
function qCard(q, {pick, reveal, showMark}) {
  const opts = q.a.map((t,i) => {
    let cls = '';
    if (reveal) {
      if (i === q.c) cls = 'good';
      else if (i === pick) cls = 'bad';
    }
    return `<li><button class="opt ${cls}" data-pick="${i}" ${reveal?'disabled':''}>
      <span class="k">${KEYS[i]}</span><span>${esc(t)}</span></button></li>`;
  }).join('');
  const mk = showMark ? `<button class="btn ghost mark" id="mark" aria-pressed="${state.marked.has(q.id)}">★ Trudne</button>` : '';
  return `<div class="qnum"><span>Pytanie ${q.id}</span>${mk}</div>
    <p class="qtext">${esc(q.q)}</p>
    <ul class="opts">${opts}</ul>`;
}

function record(q, pick) {
  if (pick === q.c) { state.right.add(q.id); state.wrong.delete(q.id); }
  else { state.wrong.add(q.id); state.right.delete(q.id); }
  save();
}

/* --- NAUKA --- */
function renderLearn() {
  const q = QUESTIONS[state.learnIdx];
  const pct = ((state.learnIdx+1)/QUESTIONS.length*100).toFixed(1);
  app.innerHTML = `
    <div class="card">
      ${qCard(q, {pick: state.learnPick, reveal: state.learnReveal, showMark: true})}
      <div class="bar">
        <button class="btn ghost" id="prev" ${state.learnIdx===0?'disabled':''}>← Poprzednie</button>
        <button class="btn ghost" id="show">${state.learnReveal?'Odpowiedź: '+KEYS[q.c]:'Pokaż odpowiedź'}</button>
        <span class="spacer"></span>
        <button class="btn" id="next" ${state.learnIdx===QUESTIONS.length-1?'disabled':''}>Następne →</button>
      </div>
      <div class="meter"><i style="width:${pct}%"></i></div>
      <p class="muted" style="margin:8px 0 0">${state.learnIdx+1} z ${QUESTIONS.length} · umiesz ${state.right.size} · do poprawy ${state.wrong.size}</p>
    </div>
    <div class="card" style="margin-top:16px">
      <div class="qnum"><span>Skocz do pytania</span></div>
      <div class="grid" id="jump">${QUESTIONS.map((x,i)=>{
        let c = i===state.learnIdx?'cur':(state.wrong.has(x.id)?'err':(state.right.has(x.id)?'ok':''));
        if (state.marked.has(x.id) && i!==state.learnIdx) c += ' mk';
        return `<button class="${c}" data-go="${i}">${x.id}</button>`;
      }).join('')}</div>
    </div>`;

  app.querySelectorAll('[data-pick]').forEach(b => b.onclick = () => {
    state.learnPick = +b.dataset.pick;
    state.learnReveal = true;
    record(q, state.learnPick);
    renderLearn();
  });
  app.querySelector('#show').onclick = () => { state.learnReveal = !state.learnReveal; renderLearn(); };
  app.querySelector('#prev').onclick = () => go(state.learnIdx-1);
  app.querySelector('#next').onclick = () => go(state.learnIdx+1);
  const m = app.querySelector('#mark');
  m.onclick = () => { state.marked.has(q.id) ? state.marked.delete(q.id) : state.marked.add(q.id); save(); renderLearn(); };
  app.querySelectorAll('[data-go]').forEach(b => b.onclick = () => go(+b.dataset.go));
  function go(i){ if(i<0||i>=QUESTIONS.length) return; state.learnIdx=i; state.learnReveal=false; state.learnPick=null; render(); window.scrollTo({top:0,behavior:'smooth'}); }
  state._go = go;
}

/* --- TEST --- */
function startTest() {
  state.test = { qs: shuffle(QUESTIONS).slice(0, TEST_SIZE), i: 0, picks: [], done: false };
  render();
}
function renderTest() {
  if (!state.test) {
    app.innerHTML = `<div class="card">
      <div class="qnum"><span>Test próbny</span></div>
      <p class="qtext">${TEST_SIZE} losowych pytań z bazy ${QUESTIONS.length} pytań.</p>
      <p class="muted">Bez podpowiedzi w trakcie — wynik i omówienie błędów zobaczysz na końcu. Próg zaliczenia przyjęty na 70% (14/20).</p>
      <div class="bar"><button class="btn" id="start">Rozpocznij test</button></div>
    </div>`;
    app.querySelector('#start').onclick = startTest;
    return;
  }
  const T = state.test;
  if (T.done) return renderResult();
  const q = T.qs[T.i];
  app.innerHTML = `<div class="card">
    <div class="qnum"><span>Pytanie ${T.i+1} / ${TEST_SIZE}</span><span>nr ${q.id}</span></div>
    <p class="qtext">${esc(q.q)}</p>
    <ul class="opts">${q.a.map((t,i)=>`<li><button class="opt ${T.picks[T.i]===i?'good':''}" data-pick="${i}">
      <span class="k">${KEYS[i]}</span><span>${esc(t)}</span></button></li>`).join('')}</ul>
    <div class="bar">
      <button class="btn ghost" id="prev" ${T.i===0?'disabled':''}>← Wstecz</button>
      <span class="spacer"></span>
      ${T.i===TEST_SIZE-1
        ? `<button class="btn" id="finish">Zakończ test</button>`
        : `<button class="btn" id="next">Dalej →</button>`}
    </div>
    <div class="meter"><i style="width:${(T.i+1)/TEST_SIZE*100}%"></i></div>
    <p class="muted" style="margin:8px 0 0">Odpowiedziano: ${T.picks.filter(x=>x!=null).length} / ${TEST_SIZE}</p>
  </div>`;
  app.querySelectorAll('[data-pick]').forEach(b => b.onclick = () => {
    T.picks[T.i] = +b.dataset.pick;
    if (T.i < TEST_SIZE-1) { T.i++; } 
    render();
  });
  const p = app.querySelector('#prev'); if (p) p.onclick = () => { T.i--; render(); };
  const n = app.querySelector('#next'); if (n) n.onclick = () => { T.i++; render(); };
  const f = app.querySelector('#finish'); if (f) f.onclick = () => {
    T.qs.forEach((qq,i) => { if (T.picks[i] != null) record(qq, T.picks[i]); });
    T.done = true; render(); window.scrollTo({top:0});
  };
}
function renderResult() {
  const T = state.test;
  const good = T.qs.filter((q,i) => T.picks[i] === q.c).length;
  const pct = Math.round(good/TEST_SIZE*100);
  const pass = pct >= 70;
  app.innerHTML = `<div class="card">
    <div class="qnum"><span>Wynik testu</span><span class="tag ${pass?'ok':'err'}">${pass?'zaliczony':'niezaliczony'}</span></div>
    <p class="score" style="color:${pass?'var(--go)':'var(--stop)'}">${good}/${TEST_SIZE}</p>
    <div class="meter" style="margin-top:14px"><i style="width:${pct}%;background:${pass?'var(--go)':'var(--stop)'}"></i></div>
    <p class="muted" style="margin-top:8px">${pct}% poprawnych odpowiedzi</p>
    <div class="bar"><button class="btn" id="again">Nowy test</button>
      <button class="btn ghost" id="toreview">Powtórz błędne (${state.wrong.size})</button></div>
  </div>
  <div class="card" style="margin-top:16px">
    <div class="qnum"><span>Omówienie</span></div>
    <div style="margin-top:10px">
    ${T.qs.map((q,i) => {
      const ok = T.picks[i] === q.c;
      return `<div class="list-item">
        <div class="qnum"><span>nr ${q.id}</span><span class="tag ${ok?'ok':'err'}">${ok?'dobrze':'źle'}</span></div>
        <p style="font-weight:600;margin:6px 0 8px">${esc(q.q)}</p>
        ${!ok && T.picks[i]!=null ? `<p class="muted" style="margin:0 0 4px">Twoja odpowiedź: ${KEYS[T.picks[i]]}) ${esc(q.a[T.picks[i]])}</p>` : ''}
        ${!ok && T.picks[i]==null ? `<p class="muted" style="margin:0 0 4px">Brak odpowiedzi</p>` : ''}
        <p style="margin:0;color:var(--go);font-weight:600">${KEYS[q.c]}) ${esc(q.a[q.c])}</p>
      </div>`;
    }).join('')}
    </div>
  </div>`;
  app.querySelector('#again').onclick = startTest;
  app.querySelector('#toreview').onclick = () => setView('review');
}

/* --- POWTÓRKA --- */
function reviewPool() {
  return QUESTIONS.filter(q => state.wrong.has(q.id) || state.marked.has(q.id));
}
function renderReview() {
  const pool = reviewPool();
  if (!pool.length) {
    app.innerHTML = `<div class="card">
      <div class="qnum"><span>Do powtórki</span></div>
      <p class="qtext">Pusto — nie masz błędnych ani oznaczonych pytań.</p>
      <p class="muted">Trafiają tu pytania, w których się pomylisz, oraz te oznaczone gwiazdką „Trudne” w trybie Nauka.</p>
    </div>`;
    return;
  }
  if (state.reviewIdx >= pool.length) state.reviewIdx = 0;
  const q = pool[state.reviewIdx];
  app.innerHTML = `<div class="card">
    ${qCard(q, {pick: state.reviewPick, reveal: state.reviewReveal, showMark: true})}
    <div class="bar">
      <button class="btn ghost" id="prev" ${state.reviewIdx===0?'disabled':''}>← Poprzednie</button>
      <button class="btn ghost" id="drop">Umiem — usuń z powtórki</button>
      <span class="spacer"></span>
      <button class="btn" id="next" ${state.reviewIdx>=pool.length-1?'disabled':''}>Następne →</button>
    </div>
    <p class="muted" style="margin:12px 0 0">${state.reviewIdx+1} z ${pool.length} pytań do powtórki</p>
  </div>`;
  app.querySelectorAll('[data-pick]').forEach(b => b.onclick = () => {
    state.reviewPick = +b.dataset.pick; state.reviewReveal = true;
    if (state.reviewPick === q.c) { /* nie usuwamy automatycznie */ }
    renderReview();
  });
  app.querySelector('#mark').onclick = () => { state.marked.has(q.id)?state.marked.delete(q.id):state.marked.add(q.id); save(); renderReview(); };
  app.querySelector('#prev').onclick = () => { state.reviewIdx--; state.reviewPick=null; state.reviewReveal=false; renderReview(); };
  app.querySelector('#next').onclick = () => { state.reviewIdx++; state.reviewPick=null; state.reviewReveal=false; renderReview(); };
  app.querySelector('#drop').onclick = () => {
    state.wrong.delete(q.id); state.marked.delete(q.id); state.right.add(q.id); save();
    state.reviewPick=null; state.reviewReveal=false; renderReview();
  };
}

/* --- LISTA --- */
function renderBrowse() {
  const qq = state.query.trim().toLowerCase();
  const list = QUESTIONS.filter(q => !qq || q.q.toLowerCase().includes(qq) || q.a.some(a => a.toLowerCase().includes(qq)));
  app.innerHTML = `<div class="card">
    <div class="row">
      <input type="search" id="q" placeholder="Szukaj w pytaniach i odpowiedziach…" value="${esc(state.query)}">
      <button class="btn ghost" id="reset">Wyczyść postęp</button>
    </div>
    <div class="stat">
      <div class="muted">Umiesz<b style="color:var(--go)">${state.right.size}</b></div>
      <div class="muted">Do poprawy<b style="color:var(--stop)">${state.wrong.size}</b></div>
      <div class="muted">Oznaczone<b>${state.marked.size}</b></div>
      <div class="muted">Znaleziono<b>${list.length}</b></div>
    </div>
  </div>
  <div class="card" style="margin-top:16px">
    ${list.map(q => `<div class="list-item">
      <div class="qnum"><span>nr ${q.id}</span>${state.marked.has(q.id)?'<span class="tag">★ trudne</span>':''}</div>
      <p style="font-weight:600;margin:6px 0 8px">${esc(q.q)}</p>
      <p style="margin:0;color:var(--go);font-weight:600">${KEYS[q.c]}) ${esc(q.a[q.c])}</p>
      <p class="muted" style="margin:6px 0 0">${q.a.map((a,i)=> i===q.c?null:`${KEYS[i]}) ${esc(a)}`).filter(Boolean).join(' · ')}</p>
      <div class="bar" style="margin-top:10px"><button class="btn ghost" data-open="${q.id}">Otwórz w trybie Nauka</button></div>
    </div>`).join('') || '<p class="muted">Brak wyników.</p>'}
  </div>`;
  const inp = app.querySelector('#q');
  inp.oninput = () => { state.query = inp.value; renderBrowse(); inp2focus(); };
  function inp2focus(){ const el = app.querySelector('#q'); el.focus(); el.setSelectionRange(el.value.length, el.value.length); }
  app.querySelector('#reset').onclick = () => {
    if (!confirm('Wyczyścić cały postęp (umiesz / do poprawy / oznaczone)?')) return;
    state.right.clear(); state.wrong.clear(); state.marked.clear(); save(); renderBrowse();
  };
  app.querySelectorAll('[data-open]').forEach(b => b.onclick = () => {
    state.learnIdx = QUESTIONS.findIndex(x => x.id === +b.dataset.open);
    state.learnReveal = false; state.learnPick = null;
    setView('learn');
  });
}

/* --- router --- */
function setView(v){
  state.view = v;
  document.querySelectorAll('#nav button').forEach(b => b.setAttribute('aria-current', String(b.dataset.view === v)));
  render(); window.scrollTo({top:0});
}
function render(){
  ({learn:renderLearn, test:renderTest, review:renderReview, browse:renderBrowse})[state.view]();
}
document.querySelectorAll('#nav button').forEach(b => b.onclick = () => setView(b.dataset.view));

document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT') return;
  if (state.view === 'learn') {
    if (e.key === 'ArrowRight') { state._go(state.learnIdx+1); e.preventDefault(); }
    if (e.key === 'ArrowLeft')  { state._go(state.learnIdx-1); e.preventDefault(); }
    if (e.key === ' ') { state.learnReveal = !state.learnReveal; renderLearn(); e.preventDefault(); }
    if (['1','2','3','4'].includes(e.key)) {
      const q = QUESTIONS[state.learnIdx];
      if (!state.learnReveal) { state.learnPick = +e.key-1; state.learnReveal = true; record(q, state.learnPick); renderLearn(); }
    }
  }
  if (state.view === 'test' && state.test && !state.test.done && ['1','2','3','4'].includes(e.key)) {
    const T = state.test; T.picks[T.i] = +e.key-1; if (T.i < TEST_SIZE-1) T.i++; render();
  }
});
render();
</script>
</body>
</html>
